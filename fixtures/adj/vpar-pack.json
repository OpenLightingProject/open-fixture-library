{
  "$schema": "https://raw.githubusercontent.com/OpenLightingProject/open-fixture-library/master/schemas/fixture.json",
  "name": "VPar Pack",
  "categories": ["Color Changer", "Dimmer"],
  "meta": {
    "authors": ["Anto for Oh show"],
    "createDate": "2026-07-14",
    "lastModifyDate": "2026-07-14"
  },
  "links": {
    "manual": [
      "https://www.adj.eu/mwdownloads/download/link/id/642"
    ],
    "productPage": [
      "https://www.adj.eu/vpar-pak"
    ]
  },
  "physical": {
    "power": 20,
    "DMXconnector": "3-pin",
    "bulb": {
      "type": "4 in 1 led RGBA"
    },
    "lens": {
      "degreesMinMax": [40, 40]
