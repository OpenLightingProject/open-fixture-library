  "availableChannels": {
    "Red": {
      "capability": {
        "type": "ColorIntensity",
        "color": "Red"
      }
    },
    "Green": {
      "capability": {
        "type": "ColorIntensity",
        "color": "Green"
      }
    },
    "Blue": {
      "capability": {
        "type": "ColorIntensity",
        "color": "Blue"
      }
    },
    "Amber": {
      "capability": {
        "type": "ColorIntensity",
        "color": "Amber"
      }
    },
    "Intensity": {
      "capability": {
        "type": "Intensity"
      }
    },
    "Strobe": {
      "capability": {
        "type": "StrobeSpeed",
        "speedStart": "slow",
        "speedEnd": "fast"
      }
    },
    "Color Macros": {
      "capability": {
        "type": "ColorPreset"
      }
    }
  },
  "modes": [
    {
      "name": "Basic 7 channels",
      "channels": [
        "Red",
        "Green",
        "Blue",
        "Amber",
        "Intensity",
        "Strobe",
        "Color Macros"
